{
  "uid": "zecca-candles",
  "title": "Zecca — Candlestick PoC",
  "tags": ["zecca", "poc", "candlestick"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "",
  "time": { "from": "now-1y", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "symbol",
        "label": "Symbol",
        "type": "query",
        "datasource": {
          "type": "motherduck-duckdb-datasource",
          "uid": "duckdb-zecca"
        },
        "query": "SELECT DISTINCT symbol FROM read_parquet('/data/gold/stocks_daily/**/*.parquet', hive_partitioning = true) ORDER BY symbol",
        "refresh": 1,
        "sort": 1,
        "current": {},
        "options": []
      },
      {
        "name": "indicator",
        "label": "Overlay field",
        "type": "query",
        "datasource": {
          "type": "motherduck-duckdb-datasource",
          "uid": "duckdb-zecca"
        },
        "query": "SELECT column_name FROM (DESCRIBE SELECT * FROM read_parquet('/data/gold/stocks_daily/**/*.parquet', hive_partitioning = true)) WHERE column_name NOT IN ('timeframe', 'year', 'month', 'symbol', 'open', 'high', 'low', 'close', 'volume') ORDER BY column_name",
        "refresh": 1,
        "sort": 1,
        "current": {},
        "options": []
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "candlestick",
      "title": "$symbol — Daily OHLC",
      "datasource": {
        "type": "motherduck-duckdb-datasource",
        "uid": "duckdb-zecca"
      },
      "gridPos": { "h": 14, "w": 24, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": { "custom": { "axisPlacement": "auto" } },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "indicator_value" },
            "properties": [
              { "id": "displayName", "value": "$indicator" },
              { "id": "custom.drawStyle", "value": "line" },
              { "id": "custom.lineWidth", "value": 2 },
              { "id": "custom.axisPlacement", "value": "right" },
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "orange" } }
            ]
          }
        ]
      },
      "options": {
        "mode": "candles",
        "candleStyle": "candles",
        "colorStrategy": "open-close",
        "colors": { "up": "green", "down": "red" },
        "includeAllFields": true
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "motherduck-duckdb-datasource",
            "uid": "duckdb-zecca"
          },
          "editorMode": "code",
          "format": 1,
          "rawSql": "SELECT timeframe AS \"time\", open, high, low, close, ${indicator:raw} AS indicator_value FROM read_parquet('/data/gold/stocks_daily/**/*.parquet', hive_partitioning = true) WHERE symbol = ${symbol:sqlstring} AND $__timeFilter(timeframe) ORDER BY timeframe"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "$symbol — Volume",
      "datasource": {
        "type": "motherduck-duckdb-datasource",
        "uid": "duckdb-zecca"
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 14 },
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "bars", "fillOpacity": 60, "lineWidth": 0 },
          "color": { "mode": "fixed", "fixedColor": "blue" }
        },
        "overrides": []
      },
      "options": { "legend": { "showLegend": false } },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "motherduck-duckdb-datasource",
            "uid": "duckdb-zecca"
          },
          "editorMode": "code",
          "format": 1,
          "rawSql": "SELECT timeframe AS \"time\", volume FROM read_parquet('/data/gold/stocks_daily/**/*.parquet', hive_partitioning = true) WHERE symbol = ${symbol:sqlstring} AND $__timeFilter(timeframe) ORDER BY timeframe"
        }
      ]
    }
  ]
}
